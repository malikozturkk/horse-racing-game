{
  "name": "horse-racing-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test --project=chromium --grep-invert \"Visual regression\"",
    "test:visual": "playwright test --project=chromium --grep \"Visual regression\"",
    "test:visual:update": "playwright test --project=chromium --grep \"Visual regression\" --update-snapshots",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:e2e",
    "lint": "eslint . --ext .ts,.vue"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@vueuse/core": "^14.3.0",
    "@vueuse/motion": "^3.0.3",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
